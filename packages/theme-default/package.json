{
  "name": "@brickslab./theme-default",
  "version": "2.0.1",
  "private": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/brickslab/brickslab-v1.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
